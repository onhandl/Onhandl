# Dependencies — never copy these; Docker installs from package manifests
node_modules
**/node_modules

# Build artefacts
**/.next
**/dist
**/.turbo

# Environment files — injected at runtime, never baked into images
**/.env
**/.env.*
!**/.env.example

# VCS
.git
.gitignore
.gitattributes

# Editor / OS
.vscode
.idea
*.DS_Store
*.swp
*.swo

# Logs
**/*.log
**/logs

# Test / CI artefacts
**/coverage
**/.nyc_output

# Docker compose files (not needed inside images)
docker-compose*.yml

# Docs / proposal (not needed in runtime image)
README.md
ProjectProposal

# Nginx config (mounted as volume, not baked in)
nginx/
