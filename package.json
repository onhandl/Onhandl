{
  "name": "onhandl-root",
  "private": true,
  "scripts": {
    "dev": "NODE_ENV=development pnpm --filter \"*\" dev",
    "build": "pnpm --filter \"*\" build",
    "start": "NODE_ENV=production pnpm --filter \"*\" start",
    "format": "prettier --write .",
    "docker:dev": "bash ./scripts/dev-up.sh",
    "docker:dev:down": "docker compose down",
    "docker:dev:logs": "docker compose logs -f",
    "docker:prod:up": "docker compose -f docker-compose.prod.yml up --build -d",
    "docker:prod:down": "docker compose -f docker-compose.prod.yml down",
    "docker:prod:logs": "docker compose -f docker-compose.prod.yml logs -f",
    "deploy:prod": "bash ./scripts/deploy-prod.sh"
  },
  "devDependencies": {
    "prettier": "^3.5.3"
  }
}
