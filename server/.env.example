# ── Required ──────────────────────────────────────────────────────────────────
MONGO_URI=
JWT_SECRET=

# ── AI Providers ──────────────────────────────────────────────────────────────
# Default AI provider used for agent persona generation (ollama | gemini | openai)
DEFAULT_AI_PROVIDER=ollama

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:3b

# Optional — only required if DEFAULT_AI_PROVIDER=gemini or user selects Gemini
GEMINI_API_KEY=
# Optional — only required if DEFAULT_AI_PROVIDER=openai or user selects OpenAI
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=

# ── Email / SMTP ──────────────────────────────────────────────────────────────
# Gmail example:  host=smtp.gmail.com, port=587, user=you@gmail.com, pass=app-password
# Resend example: host=smtp.resend.com, port=587, user=resend, pass=re_xxxxx
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# ── URLs (production only) ───────────────────────────────────────────────────
# Set these explicitly in deployed environments. They can stay blank for local development.
ALLOWED_ORIGINS=
APP_URL=
API_URL=

# ── Fiber / CKB (optional — blockchain payment channel features) ──────────────
FIBER_NODE_URL=http://localhost:8227
FIBER_AUTH_TOKEN=
